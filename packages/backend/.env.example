# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mags_ai_studio"
DATABASE_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# GitHub Integration
GITHUB_TOKEN=ghp_your_github_token_here

# Embeddings & Vector Search
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai
EMBEDDING_DIMENSION=1536
VECTOR_STORE_TYPE=pgvector
OPENAI_API_KEY=sk_your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Repository Configuration
MAX_FILE_SIZE=1048576
MAX_FILES_PER_REPO=100000
SUPPORTED_LANGUAGES=js,ts,jsx,tsx,py,java,go,rs,c,cpp,cs,rb,php,swift,kt
IGNORE_PATTERNS=node_modules,dist,build,.git,venv,__pycache__,.env

# Chunking Configuration
TARGET_CHUNK_SIZE=1000
OVERLAP_SIZE=200
CHUNKING_STRATEGY=semantic

# Processing Configuration
MAX_CONCURRENT_FILES=10
MAX_CONCURRENT_EMBEDDINGS=5
BATCH_SIZE=10

# Upload Configuration
UPLOAD_DIR=/tmp/repo-uploads
MAX_UPLOAD_SIZE=104857600

# Search Configuration
SIMILARITY_THRESHOLD=0.7
SEARCH_TOP_K=10
USE_HYBRID_SEARCH=false
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_TTL=86400

# Server
NODE_ENV=development
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# JWT (PHASE 3)
JWT_SECRET=your-secret-key
JWT_EXPIRATION=15m

# Frontend URL
FRONTEND_URL=http://localhost:3000
