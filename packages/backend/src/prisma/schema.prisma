generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// PHASES 1-6: Previous models (User, Chat, Agent, Repository, etc.)
// ============================================================================
// (All existing models from Phases 1-6 remain unchanged)

model User {
  id            String        @id @default(cuid())
  email         String        @unique @db.VarChar(255)
  username      String        @unique @db.VarChar(50)
  password      String        @db.Text
  firstName     String?       @db.VarChar(100)
  lastName      String?       @db.VarChar(100)
  avatar        String?       @db.Text
  bio           String?       @db.Text
  phone         String?       @db.VarChar(20)
  emailVerified Boolean       @default(false)
  isActive      Boolean       @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations - Phases 3-6
  userRoles      UserRole[]    @relation("UserRoles")
  sessions       Session[]     @relation("UserSessions")
  chats          Chat[]        @relation("UserChats")
  agents         Agent[]       @relation("UserAgents")
  repositories   Repository[]  @relation("UserRepositories")

  // Relations - Phase 7
  apps           GeneratedApp[] @relation("UserApps")
  buildLogs      AppBuild[]    @relation("UserBuilds")
  deployments    Deployment[]  @relation("UserDeployments")

  @@index([email])
  @@index([username])
  @@map("users")
}

// (Previous models from Phases 3-6)

// ============================================================================
// PHASE 7: AI App Builder System (NEW)
// ============================================================================

model GeneratedApp {
  id            String   @id @default(cuid())
  userId        String
  
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  prompt        String   @db.Text // Original user prompt
  
  // Tech stack and configuration
  techStack     Json     // { frontend: "nextjs", backend: "nestjs", db: "postgres" }
  architecture  Json?    // Architecture plan
  
  // Status tracking
  status        String   @db.VarChar(50) @default("draft") // draft, generating, ready, deployed, archived
  generationProgress Int @default(0)
  
  // Versions and branches
  currentVersionId String?
  lastGeneratedAt DateTime?
  lastDeployedAt  DateTime?
  
  // Repository linking (optional)
  linkedRepoId  String?
  
  // Statistics
  fileCount     Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User     @relation("UserApps", fields: [userId], references: [id], onDelete: Cascade)
  files         AppFile[] @relation("AppFiles")
  versions      AppVersion[] @relation("AppVersions")
  builds        AppBuild[] @relation("AppBuilds")
  deployments   Deployment[] @relation("AppDeployments")
  generationJobs GenerationJob[] @relation("AppGenerationJobs")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("generated_apps")
}

model AppFile {
  id            String   @id @default(cuid())
  appId         String
  
  path          String   @db.VarChar(500) // e.g., "packages/frontend/src/components/Button.tsx"
  name          String   @db.VarChar(255)
  language      String   @db.VarChar(50) // typescript, javascript, python, sql, json, yaml, etc.
  
  // Content and metadata
  content       String   @db.Text // File content
  size          Int      // File size in bytes
  
  // Generation metadata
  generatedBy   String?  @db.VarChar(100) // Which service generated this (backend-gen, frontend-gen, etc.)
  
  // Change tracking
  lastModifiedAt DateTime @updatedAt
  isEdited      Boolean  @default(false) // User has manually edited
  
  createdAt     DateTime @default(now())

  // Relations
  app           GeneratedApp @relation("AppFiles", fields: [appId], references: [id], onDelete: Cascade)
  editHistory   EditHistory[] @relation("FileEdits")

  @@unique([appId, path])
  @@index([appId])
  @@index([language])
  @@map("app_files")
}

model AppVersion {
  id            String   @id @default(cuid())
  appId         String
  
  versionNumber Int      // 1, 2, 3, etc.
  prompt        String   @db.Text // Prompt used for this version
  
  // File snapshot
  filesSnapshot Json     // Snapshot of all files at this version
  
  // Status
  status        String   @db.VarChar(50) // "completed", "failed"
  
  // Metadata
  generatedAt   DateTime @default(now())
  deployedAt    DateTime?
  
  createdAt     DateTime @default(now())

  // Relations
  app           GeneratedApp @relation("AppVersions", fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, versionNumber])
  @@index([appId])
  @@map("app_versions")
}

model AppBuild {
  id            String   @id @default(cuid())
  userId        String
  appId         String
  
  // Build configuration
  buildNumber   Int
  status        String   @db.VarChar(50) @default("pending") // pending, building, success, failed
  
  // Build artifacts
  logs          String?  @db.Text
  errors        String?  @db.Text
  warnings      String?  @db.Text
  
  // Build stats
  duration      Int?     // Duration in ms
  startedAt     DateTime?
  completedAt   DateTime?
  
  // Artifacts
  artifacts     Json?    // Build output information
  
  createdAt     DateTime @default(now())

  // Relations
  user          User     @relation("UserBuilds", fields: [userId], references: [id], onDelete: Cascade)
  app           GeneratedApp @relation("AppBuilds", fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, buildNumber])
  @@index([userId])
  @@index([appId])
  @@index([status])
  @@map("app_builds")
}

model Deployment {
  id            String   @id @default(cuid())
  userId        String
  appId         String
  
  // Deployment info
  deploymentNumber Int
  provider      String   @db.VarChar(100) // "vercel", "heroku", "docker", etc.
  environment   String   @db.VarChar(50) @default("production")
  
  // Status
  status        String   @db.VarChar(50) @default("pending") // pending, deploying, live, failed, rolled_back
  
  // URLs and endpoints
  liveUrl       String?  @db.VarChar(500)
  apiUrl        String?  @db.VarChar(500)
  
  // Metadata
  deployedBy    String?  // User ID who triggered deployment
  deployedAt    DateTime?
  duration      Int?     // Duration in ms
  
  // Logs
  logs          String?  @db.Text
  errorMessage  String?  @db.Text
  
  // Environment variables used
  envVarsHash   String?  @db.VarChar(100) // Hash of used env vars for audit
  
  // Rollback support
  previousDeploymentId String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User     @relation("UserDeployments", fields: [userId], references: [id], onDelete: Cascade)
  app           GeneratedApp @relation("AppDeployments", fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, deploymentNumber])
  @@index([userId])
  @@index([appId])
  @@index([status])
  @@index([provider])
  @@map("deployments")
}

model GenerationJob {
  id            String   @id @default(cuid())
  appId         String
  
  // Job configuration
  jobType       String   @db.VarChar(50) // "initial_generation", "regenerate_file", "regenerate_all"
  
  // Status and progress
  status        String   @db.VarChar(50) @default("pending") // pending, planning, generating, validating, completed, failed
  progress      Int      @default(0) // Percentage
  
  // Tracking
  currentStep   String?  @db.VarChar(100)
  totalSteps    Int      @default(0)
  
  // Results
  generatedFiles String[] @default([]) // File IDs generated
  logs          String?  @db.Text
  errors        String?  @db.Text
  
  // Timing
  startedAt     DateTime?
  completedAt   DateTime?
  duration      Int?
  
  createdAt     DateTime @default(now())

  // Relations
  app           GeneratedApp @relation("AppGenerationJobs", fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@index([status])
  @@map("generation_jobs")
}

model EditHistory {
  id            String   @id @default(cuid())
  fileId        String
  
  // Edit information
  originalContent String @db.Text
  newContent    String   @db.Text
  
  // AI regeneration tracking
  regeneratedBy String?  @db.VarChar(100) // AI service that regenerated
  
  createdAt     DateTime @default(now())

  // Relations
  file          AppFile @relation("FileEdits", fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([createdAt])
  @@map("edit_history")
}
